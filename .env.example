PORT=3000

# OpenAI-compatible backend URL (ví dụ: LM Studio, Ollama, vLLM, Together, v.v.)
OPENAI_BASE_URL=http://localhost:11434/v1

# API key cho backend OpenAI-compatible (để trống nếu không cần)
OPENAI_API_KEY=sk-your-key-here

# Model mặc định nếu client không gửi hoặc dùng tên claude-xxx
# Để trống = dùng tên model từ client nguyên bản
DEFAULT_MODEL=

# Map tên model Anthropic → tên model OpenAI
# Format: claude-3-5-sonnet-20241022=gpt-4o,claude-3-haiku-20240307=gpt-4o-mini
MODEL_MAP=claude-opus-4-6=gpt-4o,claude-3-5-sonnet-20241022=gpt-4o,claude-3-haiku-20240307=gpt-4o-mini,claude-3-5-haiku-20241022=gpt-4o-mini
